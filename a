-- 2. وظيفة السيرفر هوب مع إعادة المحاولة
local function serverHop()
    local ts = game:GetService("TeleportService")
    local http = game:GetService("HttpService")
    statusLabel.Text = "بحث عن سيرفر جديد..."
    
    while true do 
        local success, servers = pcall(function()
            return http:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"))
        end)
        
        if success then
            for _, server in pairs(servers.data) do
                if server.playing < server.maxPlayers and server.id ~= game.JobId then
                    statusLabel.Text = "جاري الانتقال..."
                    pcall(function()
                        ts:TeleportToPlaceInstance(game.PlaceId, server.id, player)
                    end)
                end
            end
        end
        statusLabel.Text = "فشل! إعادة محاولة..."
        task.wait(2)
    end
end

-- 3. تنفيذ الفرم التلقائي (يبدأ فوراً عند التشغيل)
local function startFarming()
    task.wait(1) -- تأخير بسيط عشان الماب يحمل
    statusLabel.Text = "جاري التجميع السريع..."
    
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    
    local locations = {
        CFrame.new(423.992432, -8.54999161, -340, 1, 0, 0, 0, 1, 0, 0, 0, 1),
        CFrame.new(4985, 4.74950027, 532.574951, 1, 0, 0, 0, 1, 0, 0, 0, 1),
        CFrame.new(2246.75, -16.9999886, -245.317535, 1, 0, 0, 0, 1, 0, 0, 0, 1)
    }

    -- انتقال سريع بين النقاط
    for i, target in ipairs(locations) do
        root.CFrame = target
        task.wait(0.3) -- وقت كافي لتسجيل النقطة
    end

    statusLabel.Text = "تم! انتظر للسيرفر هوب..."
    task.wait(5) -- وقت أمان
    serverHop()
end

-- تشغيل الفانكشن تلقائياً
startFarming()
