if not game:IsLoaded() then game.Loaded:Wait() end
local player = game.Players.LocalPlayer
local currentServerId = game.JobId -- حفظ رقم السيرفر الحالي عشان نتجنبه

-- الواجهة
local screenGui = player.PlayerGui:FindFirstChild("AzozHub_Fixed") or Instance.new("ScreenGui", player.PlayerGui)
screenGui.Name = "AzozHub_Fixed"
screenGui.ResetOnSpawn = false
local frame = screenGui:FindFirstChild("Frame") or Instance.new("Frame", screenGui)
frame.Size = UDim2.new(0, 220, 0, 70)
frame.Position = UDim2.new(0.5, -110, 0.05, 0)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
local status = frame:FindFirstChild("Label") or Instance.new("TextLabel", frame)
status.Size = UDim2.new(1, 0, 1, 0)
status.TextColor3 = Color3.fromRGB(255, 50, 50) -- لون أحمر للتنبيه
status.BackgroundTransparency = 1
status.Text = "جاري الفرم..."

-- وظيفة الانتقال لسيرفر "مختلف" غصب
local function jumpToNewServer()
    status.Text = "البحث عن سيرفر جديد تماماً..."
    local ts = game:GetService("TeleportService")
    local http = game:GetService("HttpService")
    local api = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
    
    local success, servers = pcall(function()
        return http:JSONDecode(game:HttpGet(api))
    end)
    
    if success and servers.data then
        for _, server in pairs(servers.data) do
            -- الشرط السحري: لازم السيرفر مو فل + ايديه يختلف عن السيرفر الحالي
            if server.id ~= currentServerId and server.playing < server.maxPlayers then
                status.Text = "لقيت سيرفر مختلف! جاري النحشة..."
                pcall(function()
                    ts:TeleportToPlaceInstance(game.PlaceId, server.id, player)
                end)
                task.wait(1)
            end
        end
    end
    
    -- لو كل الطرق قفلت، ننتظر شوي ونحاول مرة ثانية بدل ما ينقلنا غلط
    status.Text = "مالقيت سيرفر؟ إعادة محاولة..."
    task.wait(3)
    jumpToNewServer()
end

-- تنفيذ الفرم (المرحلة الأولى فقط)
local function start()
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart", 10)
    
    if root then
        root.CFrame = CFrame.new(423.992432, -8.54999161, -340)
        task.wait(2) -- وقت زيادة عشان نضمن إنه سجل
        jumpToNewServer()
    end
end

task.spawn(start)
